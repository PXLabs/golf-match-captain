# Golf Match Captain — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# Anthropic API key (required for AI Advisor)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Scoreboard password (Phase 2B)
# If set, the shared Scoreboard page requires this password.
# Leave blank or omit for open access on a local/private machine.
SCOREBOARD_PASSWORD=
